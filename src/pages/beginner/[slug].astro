---
import DocsLayout from '../../layouts/DocsLayout.astro';

export async function getStaticPaths() {
  const posts = await Astro.glob('../../content/beginner/*.md');
  return posts.map(post => ({
    params: { slug: post.file.split('/').pop()?.replace('.md', '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { frontmatter } = post;
const { Content } = post;
---

<DocsLayout
  title={`${frontmatter.title} - Affiliate Marketing 知识库`}
  description={frontmatter.seo_description || frontmatter.description}
  pubDate={frontmatter.pubDate}
  readTime={frontmatter.readTime}
  category="beginner"
  difficulty={frontmatter.difficulty}
>
  <Content />
</DocsLayout>
