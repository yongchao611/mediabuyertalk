---
import DocsLayout from '../../layouts/DocsLayout.astro';

const globMod = import.meta.glob('../../content/tools/*.md', { eager: true });
const tools = Object.values(globMod)
  .filter((p: any) => !p.frontmatter.draft);

const catLabels: Record<string, { label: string; emoji: string }> = {
  tracking: { label: '追踪工具', emoji: '📊' },
  'lp-builder': { label: 'LP 构建', emoji: '🏗️' },
  ai: { label: 'AI 工具', emoji: '🤖' },
  creative: { label: '创意工具', emoji: '🎨' },
  research: { label: '研究工具', emoji: '🔬' },
  spy: { label: 'Spy 工具', emoji: '👁️' },
  hosting: { label: '托管 & VPS', emoji: '☁️' },
  other: { label: '其他', emoji: '📦' },
};

const grouped: Record<string, any[]> = {};
tools.forEach(t => {
  const cat = t.frontmatter.category || 'other';
  if (!grouped[cat]) grouped[cat] = [];
  grouped[cat].push(t);
});
---

<DocsLayout title="工具导航 - Affiliate Marketing 知识库" description="Affiliate Marketing 必备工具推荐">
  <div>
    {tools.length > 0 ? (
      <div class="space-y-10">
        {Object.entries(grouped).map(([catKey, items]) => {
          const catInfo = catLabels[catKey] || catLabels.other;
          return (
            <div>
              <h2 class="text-lg font-bold text-gray-900 mb-3 flex items-center gap-2">
                <span>{catInfo.emoji}</span>
                <span>{catInfo.label}</span>
                <span class="text-sm font-normal text-gray-400">({items.length})</span>
              </h2>
              <div class="divide-y divide-gray-100 border border-gray-200 rounded-lg bg-white overflow-hidden">
                {items.map(tool => {
                  const fm = tool.frontmatter;
                  return (
                    <div class="flex items-center gap-4 px-5 py-4 hover:bg-gray-50 transition-colors">
                      {fm.icon ? (
                        <img src={fm.icon} alt={fm.title} class="w-10 h-10 rounded-lg object-cover border border-gray-100 flex-shrink-0" />
                      ) : (
                        <span class="w-10 h-10 rounded-lg bg-gray-100 flex items-center justify-center text-lg flex-shrink-0">🛠️</span>
                      )}
                      <div class="flex-1 min-w-0">
                        <h3 class="text-[15px] font-semibold text-gray-900">{fm.title}</h3>
                        {fm.description && <p class="text-sm text-gray-500 mt-0.5">{fm.description}</p>}
                      </div>
                      {fm.website_url && (
                        <a href={fm.website_url} target="_blank" rel="nofollow noopener" class="flex-shrink-0 px-4 py-2 bg-gray-100 hover:bg-brand-500 hover:text-white text-sm font-medium text-gray-600 rounded-lg transition-colors">
                          访问 →
                        </a>
                      )}
                    </div>
                  );
                })}
              </div>
            </div>
          );
        })}
      </div>
    ) : (
      <div class="text-center py-16 text-gray-400">即将更新</div>
    )}
  </div>
</DocsLayout>
