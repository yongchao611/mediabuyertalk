---
import DocsLayout from '../../layouts/DocsLayout.astro';

export async function getStaticPaths() {
  const posts = await Astro.glob('../../content/top-networks/*.md');
  return posts.map(post => ({
    params: { slug: post.file.split('/').pop()?.replace('.md', '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { frontmatter } = post;
const { Content } = post;
---

<DocsLayout
  title={`${frontmatter.title} - TOP联盟 - Affiliate Marketing 知识库`}
  description={frontmatter.description || frontmatter.title}
  category="top-networks"
>
  <!-- 联盟信息卡片 -->
  <div class="mb-8 p-6 bg-gradient-to-r from-blue-50 to-indigo-50 dark:from-blue-950 dark:to-indigo-950 rounded-xl border border-blue-200 dark:border-blue-800">
    <div class="flex items-center gap-4 mb-4">
      {frontmatter.icon ? (
        <img src={frontmatter.icon} alt={frontmatter.title} class="w-16 h-16 rounded-xl object-cover flex-shrink-0" />
      ) : (
        <span class="w-16 h-16 rounded-xl bg-gray-200 dark:bg-gray-700 flex items-center justify-center text-3xl">🏆</span>
      )}
      <div>
        <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100">{frontmatter.title}</h2>
        {frontmatter.description && (
          <p class="text-gray-600 dark:text-gray-400 mt-1">{frontmatter.description}</p>
        )}
      </div>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mt-4">
      <div class="bg-white dark:bg-gray-800 rounded-lg p-3 text-center">
        <div class="text-lg font-bold text-green-600 dark:text-green-400">{frontmatter.min_payout || '-'}</div>
        <div class="text-xs text-gray-500 dark:text-gray-400">起付金额</div>
      </div>
      <div class="bg-white dark:bg-gray-800 rounded-lg p-3 text-center">
        <div class="text-lg font-bold text-blue-600 dark:text-blue-400">{frontmatter.payment_frequency || '-'}</div>
        <div class="text-xs text-gray-500 dark:text-gray-400">支付周期</div>
      </div>
      <div class="bg-white dark:bg-gray-800 rounded-lg p-3 text-center col-span-2">
        <a
          href={frontmatter.signup_url || '#'}
          target="_blank"
          rel="nofollow noopener"
          class="inline-block px-6 py-2.5 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-lg transition-colors"
        >
          立即注册 →
        </a>
      </div>
    </div>
  </div>

  <!-- 正文（如果有的话） -->
  <Content />
</DocsLayout>
