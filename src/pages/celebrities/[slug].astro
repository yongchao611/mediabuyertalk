---
import DocsLayout from '../../layouts/DocsLayout.astro';

export async function getStaticPaths() {
  const posts = await Astro.glob('../../content/celebrities/*.md');
  return posts.map(post => ({
    params: { slug: post.file.split('/').pop()?.replace('.md', '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { frontmatter } = post;
const { Content } = post;
---

<DocsLayout
  title={`${frontmatter.title} - 名人介绍 - Affiliate Marketing 知识库`}
  description={frontmatter.seo_description || frontmatter.description || frontmatter.title}
  pubDate={frontmatter.pubDate}
  category="celebrities"
>
  {frontmatter.image && (
    <img src={frontmatter.image} alt={frontmatter.title} class="w-full max-h-80 object-cover rounded-xl mb-6" />
  )}
  <Content />
</DocsLayout>
