---
import DocsLayout from '../../layouts/DocsLayout.astro';

const globMod = import.meta.glob('../../content/rebate/*.md', { eager: true });
const posts = Object.values(globMod).filter((p: any) => !p.frontmatter.draft)
  .sort((a: any, b: any) => new Date(b.frontmatter.pubDate || 0).getTime() - new Date(a.frontmatter.pubDate || 0).getTime());
---

<DocsLayout title="返利网" description="">
  <div>
    {posts.map(p => {
      const fm = p.frontmatter;
      const fp = p.file || '';
      const parts = fp.split('/');
      const slug = parts[parts.length - 1]?.replace('.md', '') || '';
      return (
        <a href={`/rebate/${slug}/`} class="flex items-start gap-4 px-5 py-4 hover:bg-gray-50 mb-3 rounded-lg border border-gray-300 hover:border-gray-400 transition-colors">
          <div class="h-10 w-10 flex-none rounded-lg bg-cyan-50 text-cyan-600 flex items-center justify-center">
            <svg class="w-5 h-5" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1.41 16.09V20h-2.67v-1.93c-1.71-.36-3.16-1.46-3.27-3.4h1.96c.1 1.05.82 1.87 2.65 1.87 1.96 0 2.4-.98 2.4-1.59 0-.83-.44-1.61-2.67-2.14-2.48-.6-4.18-1.62-4.18-3.67 0-1.72 1.39-2.84 3.11-3.21V4h2.67v1.95c1.86.45 2.79 1.86 2.85 3.39H14.3c-.05-1.11-.64-1.87-2.22-1.87-1.5 0-2.4.68-2.4 1.64 0 .84.65 1.39 2.67 1.91s4.18 1.39 4.18 3.91c-.01 1.83-1.38 2.83-3.12 3.16z" fill="currentColor"/></svg>
          </div>
          <div class="min-w-0 flex-1">
            <span class="text-[15px] font-semibold text-gray-900">{fm.title}</span>
            <p class="mt-0.5 text-sm text-gray-500 line-clamp-2">{fm.description || ''}</p>
            <div class="mt-1 flex items-center gap-x-3 text-xs text-gray-400">
              {fm.author && <span>{fm.author}</span>}
              {fm.pubDate && <span>{new Date(fm.pubDate).toLocaleDateString('zh-CN')}</span>}
            </div>
          </div>
        </a>
      );
    })}
  </div>
</DocsLayout>
