---
import DocsLayout from '../../layouts/DocsLayout.astro';

const posts = (await Astro.glob('../../content/landing-page-library/*.md'))
  .filter(p => !p.frontmatter.draft)
  .sort((a, b) => new Date(b.frontmatter.pubDate || 0).getTime() - new Date(a.frontmatter.pubDate || 0).getTime());
---

<DocsLayout title="LP库 - Affiliate Marketing 知识库" description="落地页素材和设计思路拆解，收录高质量 Landing Page 案例">
  <section>
    <header class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-2">📄 LP库</h1>
      <p class="text-lg text-gray-600 dark:text-gray-400">落地页素材和设计思路深度拆解，提升你的转化率</p>
    </header>

    {posts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {posts.map(post => {
          const fm = post.frontmatter;
          const filePath = post.file || '';
          const parts = filePath.split('/');
          const col = parts[parts.length - 2] || 'landing-page-library';
          const s = parts[parts.length - 1]?.replace('.md', '') || '';
          const url = `/${col}/${s}/`;
          return (
            <a
              href={url}
              class="group block bg-white dark:bg-gray-800 rounded-xl border border-gray-100 dark:border-gray-700 hover:border-blue-200 dark:hover:border-blue-600 hover:shadow-lg hover:-translate-y-1 transition-all duration-200 overflow-hidden"
            >
              <!-- 封面图 -->
              {fm.image ? (
                <img src={fm.image} alt={fm.title} class="w-full h-40 object-cover" />
              ) : (
                <div class="w-full h-40 bg-gradient-to-br from-blue-100 to-indigo-200 dark:from-blue-900 dark:to-indigo-800 flex items-center justify-center text-4xl">
                  📄
                </div>
              )}

              <div class="p-4">
                <!-- 类型标签 -->
                <div class="flex items-center gap-2 mb-2">
                  {fm.offer_type && (
                    <span class="text-xs px-2 py-0.5 rounded bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400">
                      {fm.offer_type}
                    </span>
                  )}
                  {fm.download_file && (
                    <span class="text-xs px-2 py-0.5 rounded bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400 flex items-center gap-1">
                      📥 可下载
                    </span>
                  )}
                </div>

                <!-- 标题 -->
                <h3 class="font-semibold text-gray-900 dark:text-gray-100 mb-2 line-clamp-2 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
                  {fm.title}
                </h3>

                <!-- 描述 -->
                {fm.description && (
                  <p class="text-sm text-gray-500 dark:text-gray-400 line-clamp-2 mb-3">
                    {fm.description}
                  </p>
                )}

                <!-- 底部信息 -->
                <div class="flex items-center justify-between text-xs text-gray-400 dark:text-gray-500">
                  {fm.pubDate && (
                    <span>📅 {new Date(fm.pubDate).toLocaleDateString('zh-CN')}</span>
                  )}
                  {fm.readTime && (
                    <span>📖 {fm.readTime}分钟</span>
                  )}
                  {fm.download_file && (
                    <span class="text-green-600 dark:text-green-400 font-medium">免费下载</span>
                  )}
                </div>
              </div>
            </a>
          );
        })}
      </div>
    ) : (
      <div class="text-center py-16">
        <div class="text-6xl mb-4">📄</div>
        <p class="text-gray-500 dark:text-gray-400 text-lg">即将更新，敬请期待</p>
        <p class="text-gray-400 dark:text-gray-500 text-sm mt-2">正在收集高质量 Landing Page 案例</p>
      </div>
    )}
  </section>
</DocsLayout>
