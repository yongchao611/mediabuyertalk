---
import DocsLayout from '../../layouts/DocsLayout.astro';

export async function getStaticPaths() {
  const modules = import.meta.glob('../../content/landing-page-library/*.md');
  const entries = Object.entries(modules);
  if (entries.length === 0) return [];
  const posts = await Promise.all(entries.map(async ([file, loader]) => {
    const post: any = await loader();
    return { ...post, file };
  }));
  return posts.map((post: any) => ({ params: { slug: post.file.split('/').pop()?.replace('.md', '') }, props: { post } }));
}

const { post } = Astro.props;
const { frontmatter } = post;
const { Content } = post;
---

<DocsLayout title={frontmatter.title} description={frontmatter.description || frontmatter.title} pubDate={frontmatter.pubDate} readTime={frontmatter.readTime} category="landing-page-library">
  {frontmatter.image && <img src={frontmatter.image} alt={frontmatter.title} class="w-full max-h-80 object-cover rounded-xl mb-6" />}
  <Content />
</DocsLayout>
