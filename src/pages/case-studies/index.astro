---
import DocsLayout from '../../layouts/DocsLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';

const posts = (await Astro.glob('../../content/case-studies/*.md'))
  .filter(p => !p.frontmatter.draft)
  .sort((a, b) => new Date(b.frontmatter.pubDate).getTime() - new Date(a.frontmatter.pubDate).getTime());
---

<DocsLayout title="实战案例 - Affiliate Marketing 知识库" description="真实投放数据和 ROI 分析，包含 Facebook Ads、Google Ads 等渠道的实战案例">
  <section>
    <header class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-2">📊 实战案例</h1>
      <p class="text-lg text-gray-600 dark:text-gray-400">真实投放数据和 ROI 深度分析，跟着案例学投放</p>
    </header>

    {posts.length > 0 ? (
      <div class="space-y-4">
        {posts.map(post => <ArticleCard post={post} />)}
      </div>
    ) : (
      <p class="text-center text-gray-500 py-12">即将更新，敬请期待</p>
    )}
  </section>
</DocsLayout>
