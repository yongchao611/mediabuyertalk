---
import DocsLayout from '../../layouts/DocsLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';

const posts = (await Astro.glob('../../content/news/*.md'))
  .filter(p => !p.frontmatter.draft)
  .sort((a, b) => new Date(b.frontmatter.pubDate).getTime() - new Date(a.frontmatter.pubDate).getTime());
---

<DocsLayout title="行业动态 - Affiliate Marketing 知识库" description="Affiliate Marketing 行业最新动态和资讯">
  <section>
    <header class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-2">📰 行业动态</h1>
      <p class="text-lg text-gray-600 dark:text-gray-400">Affiliate Marketing 行业最新动态和资讯</p>
    </header>

    {posts.length > 0 ? (
      <div class="space-y-4">
        {posts.map(post => <ArticleCard post={post} />)}
      </div>
    ) : (
      <p class="text-center text-gray-500 py-12">即将更新，敬请期待</p>
    )}
  </section>
</DocsLayout>
