---
import DocsLayout from '../../layouts/DocsLayout.astro';

const globMod = import.meta.glob('../../content/automation-tools/*.md', { eager: true });
const posts = Object.values(globMod).filter((p: any) => !p.frontmatter.draft)
  .sort((a: any, b: any) => new Date(b.frontmatter.pubDate || 0).getTime() - new Date(a.frontmatter.pubDate || 0).getTime());
---

<DocsLayout title="自动化工具" description="">
  <div>
    {posts.map(p => {
      const fm = p.frontmatter;
      const fp = p.file || '';
      const parts = fp.split('/');
      const slug = parts[parts.length - 1]?.replace('.md', '') || '';
      return (
        <a href={`/automation-tools/${slug}/`} class="flex items-start gap-4 px-5 py-4 hover:bg-gray-50 mb-3 rounded-lg border border-gray-300 hover:border-gray-400 transition-colors">
          <div class="h-10 w-10 flex-none rounded-lg bg-violet-50 text-violet-600 flex items-center justify-center">
            <svg class="w-5 h-5" viewBox="0 0 24 24"><path d="M20 7h-2V5c0-1.1-.9-2-2-2H8C6.9 3 6 3.9 6 5v2H4c-1.1 0-2 .9-2 2v9c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V9c0-1.1-.9-2-2-2zM8 5h8v2H8V5zm12 13H4V9h16v9z" fill="currentColor"/><circle cx="12" cy="13.5" r="1.5" fill="currentColor"/><path d="M15 16.5c0-.6-.4-1-1-1h-4c-.6 0-1 .4-1 1s.4 1 1 1h4c.6 0 1-.4 1-1z" fill="currentColor"/></svg>
          </div>
          <div class="min-w-0 flex-1">
            <span class="text-[15px] font-semibold text-gray-900">{fm.title}</span>
            <p class="mt-0.5 text-sm text-gray-500 line-clamp-2">{fm.description || ''}</p>
            <div class="mt-1 flex items-center gap-x-3 text-xs text-gray-400">
              {fm.author && <span>{fm.author}</span>}
              {fm.pubDate && <span>{new Date(fm.pubDate).toLocaleDateString('zh-CN')}</span>}
            </div>
          </div>
        </a>
      );
    })}
  </div>
</DocsLayout>
