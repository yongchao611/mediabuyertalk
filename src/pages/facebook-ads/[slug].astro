---
import DocsLayout from '../../layouts/DocsLayout.astro';

export async function getStaticPaths() {
  const posts = await Astro.glob('../../content/facebook-ads/*.md');
  return posts.map(post => ({
    params: { slug: post.file.split('/').pop()?.replace('.md', '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { frontmatter } = post;
const { Content } = post;
---

<DocsLayout
  title={`${frontmatter.title} - Facebook Ads - Affiliate Marketing 知识库`}
  description={frontmatter.seo_description || frontmatter.description || frontmatter.title}
  pubDate={frontmatter.pubDate}
  readTime={frontmatter.readTime}
  category="facebook-ads"
>
  <!-- 封面图片 -->
  {frontmatter.image && (
    <img src={frontmatter.image} alt={frontmatter.title} class="w-full h-64 object-cover rounded-xl mb-6" />
  )}
  <Content />
</DocsLayout>
