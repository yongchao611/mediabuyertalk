---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MobileMenu from '../components/MobileMenu.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import TableOfContents from '../components/TableOfContents.astro';
import RelatedPosts from '../components/RelatedPosts.astro';

export interface Props {
  title: string;
  description?: string;
  pubDate?: Date;
  readTime?: number;
  category?: string;
  difficulty?: string;
  headings?: { depth: number; text: string }[];
  relatedPosts?: any[];
}

const {
  title,
  description,
  pubDate,
  readTime,
  category,
  difficulty,
  headings = [],
  relatedPosts = [],
} = Astro.props;
---

<BaseLayout title={title} description={description}>
  <Header />
  <MobileMenu />

  <main class="flex-1">
    <div class="container mx-auto px-4 py-8">
      <div class="flex gap-8">
        <!-- 文章主体 -->
        <article class="flex-1 min-w-0 max-w-3xl mx-auto">
          <!-- 面包屑 -->
          <Breadcrumb category={category} title={title} />

          <!-- 文章头部信息 -->
          <header class="mb-8">
            <h1 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-gray-100 mb-4">
              {title}
            </h1>

            {description && (
              <p class="text-lg text-gray-600 dark:text-gray-400 mb-4">{description}</p>
            )}

            <div class="flex flex-wrap items-center gap-4 text-sm text-gray-500 dark:text-gray-400">
              {pubDate && (
                <span class="flex items-center gap-1">
                  📅 {new Date(pubDate).toLocaleDateString('zh-CN')}
                </span>
              )}
              {readTime && (
                <span class="flex items-center gap-1">📖 {readTime} 分钟阅读</span>
              )}
              {category && (
                <span class="flex items-center gap-1">📂 {category}</span>
              )}
              {difficulty && (
                <span class="flex items-center gap-1">📊 难度: {difficulty}</span>
              )}
            </div>
          </header>

          <!-- 文章内容 -->
          <div class="prose-custom">
            <slot />
          </div>
        </article>

        <!-- 侧边栏 - 右侧目录 -->
        {headings.length > 0 && (
          <aside class="hidden lg:block w-64 flex-shrink-0">
            <div class="sticky top-24">
              <TableOfContents headings={headings} />
            </div>
          </aside>
        )}
      </div>

      <!-- 相关文章 -->
      {relatedPosts.length > 0 && (
        <div class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-700">
          <RelatedPosts posts={relatedPosts} />
        </div>
      )}
    </div>
  </main>

  <Footer />
</BaseLayout>
