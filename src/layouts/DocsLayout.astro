---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description?: string;
  pubDate?: Date;
  readTime?: number;
  category?: string;
}

const { title, description, pubDate, readTime, category } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <Header />

  <main class="flex-1">
    <div class="mx-auto max-w-3xl px-4 py-8">
      <!-- 面包屑 -->
      {category && (
        <div class="text-sm text-gray-400 dark:text-gray-500 mb-6">
          <a href="/" class="hover:text-gray-600 dark:hover:text-gray-300">首页</a>
          <span class="mx-1.5">/</span>
          <a href={`/${category}/`} class="hover:text-gray-600 dark:hover:text-gray-300">{category}</a>
          <span class="mx-1.5">/</span>
          <span class="text-gray-600 dark:text-gray-400 truncate">{title}</span>
        </div>
      )}

      <article class="max-w-none">
        <header class="mb-8">
          <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-3">{title}</h1>
          {description && (
            <p class="text-base text-gray-500 dark:text-gray-400 mb-2">{description}</p>
          )}
          <div class="flex items-center gap-3 text-sm text-gray-400 dark:text-gray-500">
            {pubDate && <span>{new Date(pubDate).toLocaleDateString('zh-CN')}</span>}
            {readTime && <span>{readTime} 分钟阅读</span>}
            <span data-article-slug={Astro.url.pathname.replace(/\/$/, '').split('/').pop()} data-base-views="0">👁 ...</span>
          </div>
        </header>

        <div class="prose-custom">
          <slot />
        </div>
      </article>
    </div>
  </main>

  <Footer />
</BaseLayout>
