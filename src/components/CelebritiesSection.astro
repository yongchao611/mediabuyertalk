---
import CelebrityCard from './CelebrityCard.astro';

interface Props {
  celebrities: any[];
}

const { celebrities } = Astro.props;
---

<section class="bg-gradient-to-r from-orange-50 to-pink-50 dark:from-orange-950 dark:to-pink-950 py-12">
  <div class="container mx-auto px-4">
    <div class="flex justify-between items-center mb-6">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100">⭐ 行业大咖</h2>
      <a href="/celebrities/" class="text-orange-600 dark:text-orange-400 hover:underline text-sm font-medium">
        查看全部 →
      </a>
    </div>
    {celebrities.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        {celebrities.map(celeb => <CelebrityCard celebrity={celeb} />)}
      </div>
    ) : (
      <p class="text-center text-gray-500 dark:text-gray-400 py-8">即将上线，敬请期待</p>
    )}
  </div>
</section>
