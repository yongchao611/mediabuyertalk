---
const navItems = [
  { label: '新手入门', href: '/beginner/', icon: '🎓' },
  { label: 'Facebook Ads', href: '/facebook-ads/', icon: '📘' },
  { label: 'Google Ads', href: '/google-ads/', icon: '🔍' },
  { label: 'TOP Offer', href: '/top-offers/', icon: '💰' },
  { label: '返利网', href: '/rebate/', icon: '💸' },
  { label: 'TOP联盟', href: '/top-networks/', icon: '🏆' },

  { label: '实战案例', href: '/case-studies/', icon: '📊' },
  { label: '工具导航', href: '/tools/', icon: '🛠️' },
  { label: '自动化工具', href: '/automation-tools/', icon: '🤖' },
  { label: '名人介绍', href: '/celebrities/', icon: '⭐' },
  { label: '联系作者', href: '/contact/', icon: '📬' },
  { label: '行业动态', href: '/news/', icon: '📰' },
];
---

<div id="mobile-menu" class="hidden lg:hidden fixed inset-0 top-16 z-40 bg-white dark:bg-gray-950 overflow-y-auto">
  <nav class="container mx-auto px-4 py-4">
    <div class="grid grid-cols-2 gap-2">
      {navItems.map(item => (
        <a
          href={item.href}
          class="flex items-center gap-2 px-4 py-3 text-gray-700 dark:text-gray-300 hover:bg-blue-50 dark:hover:bg-blue-900/20 hover:text-blue-600 rounded-lg transition-colors"
        >
          <span class="text-xl">{item.icon}</span>
          <span class="text-sm font-medium">{item.label}</span>
        </a>
      ))}
    </div>

    <!-- 额外链接 -->
    <div class="mt-6 pt-6 border-t border-gray-200 dark:border-gray-700 space-y-2">
      <a href="/about/" class="block px-4 py-2 text-gray-600 dark:text-gray-400 hover:text-blue-600 rounded-lg transition-colors">
        📖 关于本站
      </a>
      <a href="/faq/" class="block px-4 py-2 text-gray-600 dark:text-gray-400 hover:text-blue-600 rounded-lg transition-colors">
        ❓ 常见问题
      </a>
      <a href="/search/" class="block px-4 py-2 text-gray-600 dark:text-gray-400 hover:text-blue-600 rounded-lg transition-colors">
        🔍 搜索文章
      </a>
    </div>
  </nav>
</div>
