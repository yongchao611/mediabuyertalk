---
interface Props {
  post: any;
}

const { post } = Astro.props;
const { frontmatter } = post;

// Astro.glob 不提供 url 和 collection，从 file 路径手动计算
const filePath = post.file || '';
const pathParts = filePath.split('/');
const collection = pathParts[pathParts.length - 2] || 'beginner';
const slug = pathParts[pathParts.length - 1]?.replace('.md', '') || '';
const url = `/${collection}/${slug}/`;

const categoryMap: Record<string, { label: string; color: string }> = {
  beginner: { label: '新手入门', color: 'blue' },
  'facebook-ads': { label: 'Facebook Ads', color: 'indigo' },
  'google-ads': { label: 'Google Ads', color: 'red' },
  'top-offers': { label: 'TOP Offer', color: 'green' },
  'case-studies': { label: '实战案例', color: 'pink' },
  'landing-page-library': { label: 'LP库', color: 'yellow' },
  tools: { label: '工具', color: 'teal' },
  celebrities: { label: '名人', color: 'orange' },
  'top-networks': { label: '联盟', color: 'purple' },
};

const category = categoryMap[collection] || { label: '文章', color: 'gray' };

const colorClasses: Record<string, string> = {
  blue: 'bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400',
  indigo: 'bg-indigo-100 text-indigo-700 dark:bg-indigo-900/30 dark:text-indigo-400',
  red: 'bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400',
  green: 'bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400',
  pink: 'bg-pink-100 text-pink-700 dark:bg-pink-900/30 dark:text-pink-400',
  yellow: 'bg-yellow-100 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-400',
  teal: 'bg-teal-100 text-teal-700 dark:bg-teal-900/30 dark:text-teal-400',
  orange: 'bg-orange-100 text-orange-700 dark:bg-orange-900/30 dark:text-orange-400',
  purple: 'bg-purple-100 text-purple-700 dark:bg-purple-900/30 dark:text-purple-400',
  gray: 'bg-gray-100 text-gray-700 dark:bg-gray-700 dark:text-gray-300',
};

const tagClass = colorClasses[category.color] || colorClasses.gray;
---

<div class="bg-white dark:bg-gray-800 rounded-xl p-5 border border-gray-100 dark:border-gray-700 hover:border-gray-200 dark:hover:border-gray-600 hover:shadow-md transition-all duration-200">
  <div class="flex flex-wrap items-center gap-2 mb-2">
    <span class={`text-xs px-2 py-1 rounded font-medium ${tagClass}`}>
      {category.label}
    </span>
    {frontmatter.trend === 'hot' && (
      <span class="text-xs px-2 py-1 rounded bg-orange-100 text-orange-700 dark:bg-orange-900/30 dark:text-orange-400">🔥 热门</span>
    )}
    {frontmatter.difficulty && (
      <span class="text-xs px-2 py-1 rounded bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-300">
        {frontmatter.difficulty === 'beginner' ? '入门' : frontmatter.difficulty === 'intermediate' ? '中级' : '高级'}
      </span>
    )}
  </div>

  <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 mb-2 line-clamp-2">
    <a href={url} class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
      {frontmatter.title}
    </a>
  </h3>

  <p class="text-gray-600 dark:text-gray-400 text-sm mb-3 line-clamp-2">{frontmatter.description}</p>

  <!-- Offer 特有字段 -->
  {frontmatter.epc && (
    <div class="flex flex-wrap gap-x-3 gap-y-1 text-sm text-gray-500 dark:text-gray-400 mb-2">
      <span class="text-green-600 dark:text-green-400 font-medium">EPC {frontmatter.epc}</span>
      {frontmatter.cr && <span>CR {frontmatter.cr}</span>}
      {frontmatter.network && <span>{frontmatter.network}</span>}
      {frontmatter.current_rank && (
        <span class="text-amber-500 font-medium">#{frontmatter.current_rank} 🥇</span>
      )}
    </div>
  )}

  <div class="flex flex-wrap gap-4 text-xs text-gray-400 dark:text-gray-500">
    {frontmatter.pubDate && (
      <span>📅 {new Date(frontmatter.pubDate).toLocaleDateString('zh-CN')}</span>
    )}
    {frontmatter.readTime && <span>📖 {frontmatter.readTime}分钟</span>}
    {frontmatter.geo && <span>🌍 {frontmatter.geo}</span>}
  </div>
</div>
