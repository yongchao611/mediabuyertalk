---
interface Props {
  post: any;
}

const { post } = Astro.props;
const { frontmatter } = post;

// 从文件路径计算 URL 和分类
const filePath = post.file || '';
const pathParts = filePath.split('/');
const collection = pathParts[pathParts.length - 2] || '';
const slug = pathParts[pathParts.length - 1]?.replace('.md', '') || '';
const url = `/${collection}/${slug}/`;

const catLabels: Record<string, string> = {
  'beginner': '入门',
  'facebook-ads': 'Facebook',
  'google-ads': 'Google',
  'top-offers': 'Offer',
  'top-networks': '联盟',
  'landing-page-library': 'LP库',
  'case-studies': '案例',
  'tools': '工具',
  'celebrities': '名人',
};

const avatarColors: Record<string, string> = {
  'beginner': 'bg-blue-500',
  'facebook-ads': 'bg-indigo-500',
  'google-ads': 'bg-red-500',
  'top-offers': 'bg-emerald-500',
  'top-networks': 'bg-purple-500',
  'landing-page-library': 'bg-amber-500',
  'case-studies': 'bg-pink-500',
  'tools': 'bg-teal-500',
  'celebrities': 'bg-orange-500',
};

const catLabel = catLabels[collection] || '';
const avatarColor = avatarColors[collection] || 'bg-gray-400';
const avatarLetter = catLabel?.charAt(0) || '?';
---

<div class="flex items-start gap-3 py-3.5 group">
  <!-- 分类色块 -->
  <a href={url} class="w-9 h-9 rounded-full {avatarColor} flex items-center justify-center text-white text-sm font-bold flex-shrink-0 mt-0.5 hover:opacity-80 transition-opacity">
    {avatarLetter}
  </a>

  <!-- 内容 -->
  <div class="min-w-0 flex-1">
    <h3 class="text-base font-medium text-gray-900 dark:text-gray-100 leading-snug">
      <a href={url} class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
        {frontmatter.title}
      </a>
    </h3>
    <p class="text-sm text-gray-500 dark:text-gray-400 mt-0.5 line-clamp-2">
      {frontmatter.description || ''}
    </p>
    <div class="flex items-center gap-3 mt-1.5 text-xs text-gray-400 dark:text-gray-500">
      <span>{catLabel}</span>
      {frontmatter.pubDate && <span>{new Date(frontmatter.pubDate).toLocaleDateString('zh-CN')}</span>}
      {frontmatter.readTime && <span>{frontmatter.readTime} 分钟阅读</span>}
    </div>
  </div>
</div>
