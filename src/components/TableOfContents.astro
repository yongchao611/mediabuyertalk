---
interface Heading {
  depth: number;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;

// 生成 id 用于锚点链接
function slugify(text: string): string {
  return text
    .toLowerCase()
    .replace(/[^\w一-鿿]+/g, '-')
    .replace(/^-+|-+$/g, '');
}
---

<nav class="text-sm">
  <h4 class="font-semibold text-gray-900 dark:text-gray-100 mb-3 text-base">📑 目录</h4>
  <ul class="space-y-1.5 border-l-2 border-gray-200 dark:border-gray-700">
    {headings.map((heading) => (
      <li>
        <a
          href={`#${slugify(heading.text)}`}
          class={`block text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors ${
            heading.depth === 2 ? 'pl-3 text-sm' : 'pl-6 text-xs'
          }`}
        >
          {heading.text}
        </a>
      </li>
    ))}
  </ul>
</nav>
