---
interface Network {
  name: string;
  rating: number;
  niche: string;
  payout: string;
  url: string;
}

interface Props {
  network: Network;
}

const { network } = Astro.props;

// 生成星级
function getStars(rating: number): string {
  const full = Math.floor(rating);
  const half = rating - full >= 0.5;
  let stars = '★'.repeat(full);
  if (half) stars += '☆';
  return stars;
}
---

<div class="bg-white dark:bg-gray-800 rounded-xl p-5 text-center border border-gray-100 dark:border-gray-700 hover:border-blue-200 dark:hover:border-blue-600 hover:shadow-md transition-all duration-200">
  <h3 class="font-bold text-gray-900 dark:text-gray-100 text-lg mb-2">{network.name}</h3>

  <div class="flex justify-center items-center gap-1 mb-2">
    <span class="text-yellow-400">{getStars(network.rating)}</span>
    <span class="text-sm font-medium text-gray-600 dark:text-gray-400">{network.rating}</span>
  </div>

  <p class="text-xs text-gray-500 dark:text-gray-400 bg-gray-100 dark:bg-gray-700 inline-block px-3 py-1 rounded-full mb-3">
    {network.niche}
  </p>

  <p class="text-xs text-gray-400 dark:text-gray-500 mb-4">{network.payout}</p>

  <a
    href={network.url}
    target="_blank"
    rel="nofollow noopener"
    class="inline-block w-full px-4 py-2.5 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors"
  >
    注册 →
  </a>
</div>
