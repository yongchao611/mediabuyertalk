---
interface Props {
  offer: any;
}

const { offer } = Astro.props;
const { frontmatter } = offer;

// 从文件路径计算 URL
const filePath = offer.file || '';
const pathParts = filePath.split('/');
const collection = pathParts[pathParts.length - 2] || 'top-offers';
const slug = pathParts[pathParts.length - 1]?.replace('.md', '') || '';
const url = `/${collection}/${slug}/`;

const trendEmoji: Record<string, string> = {
  up: '📈',
  down: '📉',
  stable: '➡️',
  hot: '🔥',
};
---

<div class="bg-white dark:bg-gray-800 rounded-xl p-5 border border-gray-100 dark:border-gray-700 hover:border-blue-200 dark:hover:border-blue-600 hover:shadow-md transition-all duration-200">
  <!-- Offer Header -->
  <div class="flex items-start justify-between mb-3">
    <div class="flex items-center gap-2">
      <span class="text-2xl">💰</span>
      <div>
        <h3 class="font-semibold text-gray-900 dark:text-gray-100">
          <a href={url} class="hover:text-blue-600 transition-colors">{frontmatter.title}</a>
        </h3>
        <span class="text-xs text-gray-500 dark:text-gray-400">{frontmatter.category} · {frontmatter.geo}</span>
      </div>
    </div>
    <span class="text-xs px-2 py-1 rounded bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400 font-medium">
      #{frontmatter.current_rank}
    </span>
  </div>

  <!-- Offer Metrics -->
  <div class="grid grid-cols-3 gap-3 mb-3 p-3 bg-gray-50 dark:bg-gray-900 rounded-lg">
    <div class="text-center">
      <div class="text-lg font-bold text-green-600 dark:text-green-400">{frontmatter.epc}</div>
      <div class="text-xs text-gray-500 dark:text-gray-400">EPC</div>
    </div>
    <div class="text-center">
      <div class="text-lg font-bold text-blue-600 dark:text-blue-400">{frontmatter.cr}</div>
      <div class="text-xs text-gray-500 dark:text-gray-400">CR</div>
    </div>
    <div class="text-center">
      <div class="text-lg font-bold text-purple-600 dark:text-purple-400">{frontmatter.payout}</div>
      <div class="text-xs text-gray-500 dark:text-gray-400">Payout</div>
    </div>
  </div>

  <!-- 趋势 -->
  <div class="flex items-center justify-between text-sm">
    <span class="text-gray-500 dark:text-gray-400">
      趋势: {trendEmoji[frontmatter.trend] || '➡️'} {frontmatter.trend === 'up' ? '上升' : frontmatter.trend === 'down' ? '下降' : '稳定'}
    </span>
    <span class="text-xs text-gray-400">{frontmatter.network}</span>
  </div>
</div>
